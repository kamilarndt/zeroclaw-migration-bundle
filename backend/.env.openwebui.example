# Open WebUI Configuration Example
# Copy this file to .env.openwebui and fill in your values

# Open WebUI Settings
OPEN_WEBUI_URL=http://localhost:8080
OPEN_WEBUI_USERNAME=admin
OPEN_WEBUI_PASSWORD=your-password-here

# OpenAI API Connection Settings
# Use localhost for local development
OPENAI_API_URL=http://127.0.0.1:42618/v1

# Use host.docker.internal when Open WebUI is in Docker and ZeroClaw is on the host
# OPENAI_API_URL=http://host.docker.internal:42618/v1

# Use the service name when both are in the same Docker network
# OPENAI_API_URL=http://zeroclaw:42618/v1

# API Key / Pairing Token
# Generate this from your ZeroClaw instance
OPENAI_API_KEY=sk-your-pairing-token-here

# Browser Settings
# Set to "false" to see the browser while configuring (useful for debugging)
HEADLESS=true
